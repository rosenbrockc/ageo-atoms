    {
      "node_id": "infergeometricudgedges",
      "parent_id": "graphtoudgmapping",
      "name": "InferGeometricUDGEdges",
      "description": "Builds geometric edge candidates from coordinates using blockade-radius neighborhood queries.",
      "concept_type": "geometry",
      "inputs": [
        {
          "name": "coords",
          "type_desc": "np.ndarray",
          "constraints": "Finite coordinates"
        },
        {
          "name": "blockade_radius",
          "type_desc": "float",
          "constraints": "Computed as Chadoq2.rydberg_blockade_radius(1.0)"
        },
        {
          "name": "epsilon",
          "type_desc": "float",
          "constraints": "Small positive tolerance; set to 1e-9"
        }
      ],
      "outputs": [
        {
          "name": "geometric_edges",
          "type_desc": "Set[Tuple[int, int]]",
          "constraints": "Pairs within blockade_radius * (1 + epsilon)"
        },
        {
          "name": "geometric_bonds",
          "type_desc": "np.ndarray",
          "constraints": "Coordinate rows indexed by geometric_edges tuple form"
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(coords: 2D float array (N x 2), blockade_radius: float, epsilon: float) -> tuple[Set[Tuple[int, int]], 2D float array (M x 2)]",
