    {
      "node_id": "graphtoudgmapping",
      "parent_id": "map_to_UDG_root",
      "name": "GraphToUDGMapping",
      "description": "Converts an input graph representation into a UDG-form graph as a pure, stateless transformation.",
      "concept_type": "custom",
      "inputs": [
        {
          "name": "G",
          "type_desc": "Graph",
          "constraints": "Must be a valid graph object accepted by map_to_UDG."
        }
      ],
      "outputs": [
        {
          "name": "udg",
          "type_desc": "Graph",
          "constraints": "New mapped graph output; no hidden state mutation."
        }
      ],
      "status": "decomposed",
      "children": [
        "prepareembeddinginputs",
        "optimizenodecoordinates",
        "infergeometricudgedges",
        "evaluateedgecountconsistency",
        "assemblenodepositionmapping"
      ],
      "depth": 1,
      "type_signature": "(G: Graph) -> Graph",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Deterministic Relational Topology Canonicalizer. Takes a valid relational graph structure and rewrites it into a constrained UDG-normalized topology via a fixed mapping function. The transformation is pure and stateless: it creates a new graph instance without mutating the input object. The result is a standardized structural representation suitable for downstream algorithms that assume UDG-form inputs.. Applications: Wireless sensor network modeling: normalize arbitrary connectivity data into a proximity-constrained topology for routing analysis, Molecular informatics: convert general interaction graphs into a standardized neighborhood graph for geometric feature extraction, Robotics swarms: map communication/visibility relations into a canonical local-neighbor graph for coordination algorithms, Neuroscience connectomics: transform heterogeneous connectivity encodings into a uniform graph form for comparative network metrics",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
    {
      "node_id": "prepareembeddinginputs",
      "parent_id": "graphtoudgmapping",
      "name": "PrepareEmbeddingInputs",
      "description": "Extracts graph topology and creates deterministic optimization inputs for 2D coordinate embedding.",
      "concept_type": "custom",
      "inputs": [
        {
          "name": "G",
          "type_desc": "object",
          "constraints": "Finite node/edge set"
        },
        {
          "name": "seed",
          "type_desc": "int",
          "constraints": "Fixed to 0 for reproducible initialization"
        },
        {
          "name": "distance_scale",
          "type_desc": "float",
          "constraints": "Positive; fixed to 5.0 in current implementation"
        }
      ],
      "outputs": [
        {
          "name": "adjacency_matrix",
          "type_desc": "np.ndarray",
          "constraints": "Node order aligned with node_order"
        },
        {
          "name": "scaled_adjacency",
          "type_desc": "np.ndarray",
          "constraints": "adjacency_matrix multiplied by distance_scale"
        },
        {
          "name": "layout_shape",
          "type_desc": "Tuple[int, int]",
          "constraints": "Always (N, 2)"
        },
        {
          "name": "initial_guess",
          "type_desc": "np.ndarray",
          "constraints": "Length = 2N, generated deterministically from seed"
        },
        {
          "name": "node_order",
          "type_desc": "Sequence[node]",
          "constraints": "Same ordering used for adjacency construction"
        },
        {
          "name": "original_edge_count",
          "type_desc": "int",
          "constraints": "Equals |E(G)|"
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(G: networkx.Graph, seed: int, distance_scale: float) -> tuple[Dense matrix (N x N), Dense matrix (N x N), Tuple[int, int], 1D float array, Sequence[node], int]",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
    {
      "node_id": "optimizenodecoordinates",
      "parent_id": "graphtoudgmapping",
      "name": "OptimizeNodeCoordinates",
      "description": "Runs continuous optimization to find 2D coordinates whose induced distances approximate UDG constraints.",
      "concept_type": "custom",
      "inputs": [
        {
          "name": "initial_guess",
          "type_desc": "np.ndarray",
          "constraints": "Length = 2N"
        },
        {
          "name": "scaled_adjacency",
          "type_desc": "np.ndarray",
          "constraints": "Numeric"
        },
        {
          "name": "layout_shape",
          "type_desc": "Tuple[int, int]",
          "constraints": "Second dimension is 2"
        },
        {
          "name": "optimizer_method",
          "type_desc": "str",
          "constraints": "COBYLA"
        },
        {
          "name": "optimizer_tol",
          "type_desc": "float",
          "constraints": "Positive; set to 1e-6"
        },
        {
          "name": "optimizer_maxiter",
          "type_desc": "int",
          "constraints": "Positive; set to 200000"
        }
      ],
      "outputs": [
        {
          "name": "coords",
          "type_desc": "np.ndarray",
          "constraints": "Reshaped optimizer solution"
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(initial_guess: 1D float array, scaled_adjacency: Dense matrix (N x N), layout_shape: Tuple[int, int], optimizer_method: string, optimizer_tol: float, optimizer_maxiter: int) -> 2D float array (N x 2)",
      "matched_primitive": null,
