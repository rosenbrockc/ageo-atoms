    {
      "node_id": "heart_cycle_detection",
      "parent_id": "heart_cycle_detection_root",
      "name": "heart_cycle_detection",
      "description": "Detects individual heart cycles from a PPG signal at the given sampling rate, identifying cycle boundaries or fiducial points within the waveform.",
      "concept_type": "searching",
      "inputs": [
        {
          "name": "ppg",
          "type_desc": "1-D numeric array representing the photoplethysmography waveform signal",
          "constraints": "non-empty, finite-valued samples",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "sampling_rate",
          "type_desc": "positive scalar (Hz) \u2014 number of samples per second",
          "constraints": "must be > 0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "cycle_indices",
          "type_desc": "array or list of integer sample indices marking detected heart-cycle boundaries (e.g. systolic peaks or onset points)",
          "constraints": "indices within [0, len(ppg))",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "decomposed",
      "children": [
        "normalize_ppg_signal",
