      "parent_id": "heart_cycle_detection",
      "name": "compute_beat_window_half_width",
      "description": "Derive a fixed symmetric half-window size (in samples) for segmenting individual heart cycles, based on the average inter-peak distance in the upsampled signal.",
      "concept_type": "arithmetic",
      "inputs": [
