          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "beat_bound",
          "type_desc": "positive integer (samples)",
          "constraints": "= round((len(ppg_upsampled) / len(peaks)) / 2)",
          "required": true,
          "default_value_repr": ""
