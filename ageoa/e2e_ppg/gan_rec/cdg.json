      "concept_type": "arithmetic",
      "inputs": [
        {
          "name": "noise",
          "type_desc": "list",
          "constraints": "Length defines total reconstruction target."
        },
        {
          "name": "sampling_rate",
          "type_desc": "int",
          "constraints": "Must be positive."
        },
        {
          "name": "shifting_step_seconds",
          "type_desc": "int",
          "constraints": "Fixed at 5 in current implementation."
        }
      ],
      "outputs": [
        {
          "name": "len_rec",
          "type_desc": "int",
          "constraints": "Computed as shifting_step_seconds * sampling_rate."
        },
        {
          "name": "reconstructed_noise",
          "type_desc": "list",
          "constraints": "Initialized empty."
        },
        {
          "name": "remaining_noise",
          "type_desc": "int",
          "constraints": "Initialized as len(noise)."
        },
        {
          "name": "target_noise_len",
          "type_desc": "int",
          "constraints": "Equals len(noise)."
        }
      ],
      "status": "atomic",
      "children": [],
