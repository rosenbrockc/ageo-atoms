    {
      "node_id": "generatereconstructedppg",
      "parent_id": "gan_rec_root",
      "name": "GenerateReconstructedPPG",
      "description": "Applies the GAN generator to clean PPG context and latent noise to produce reconstructed or synthetic PPG output.",
      "concept_type": "custom",
      "inputs": [
        {
          "name": "ppg_clean",
          "type_desc": "np.ndarray",
          "constraints": "Clean PPG signal input; shape must be compatible with generator input."
        },
        {
          "name": "noise",
          "type_desc": "np.ndarray",
          "constraints": "Latent noise vector/tensor aligned with generator latent dimensions."
        },
        {
          "name": "sampling_rate",
          "type_desc": "float",
          "constraints": "Sampling frequency in Hz; must be > 0."
        },
        {
          "name": "generator",
          "type_desc": "Callable",
          "constraints": "Inference-ready generator that maps inputs to reconstructed signal."
        },
        {
          "name": "device",
          "type_desc": "str",
          "constraints": "Execution device compatible with model and tensors."
        }
      ],
      "outputs": [
        {
          "name": "ppg_generated",
          "type_desc": "np.ndarray",
          "constraints": "Generated/reconstructed PPG signal; shape determined by generator architecture."
        }
      ],
      "status": "decomposed",
      "children": [
        "initializereconstructionbudget",
        "checkreconstructioncompletion",
        "synthesizenoisefromcleancontext",
        "deriveupsampledpeakanchors",
