    {
      "node_id": "audio_onset_detection",
      "parent_id": "find_onsets_zong2003_root",
      "name": "Audio Onset Detection",
      "description": "Detects note/event onset locations from an input audio signal using the Zong (2003) procedure and threshold/window parameters.",
      "concept_type": "signal_transform",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "1D numeric array",
          "constraints": "Audio waveform samples."
        },
        {
          "name": "sampling_rate",
          "type_desc": "number",
          "constraints": "Must be positive."
        },
        {
          "name": "sm_size",
          "type_desc": "integer",
          "constraints": "Smoothing size; typically > 0."
        },
        {
          "name": "size",
          "type_desc": "integer",
          "constraints": "Analysis window/feature size; typically > 0."
        },
        {
          "name": "alpha",
          "type_desc": "number",
          "constraints": "Algorithm weighting/sensitivity parameter."
        },
        {
          "name": "wrange",
          "type_desc": "integer or tuple/range",
          "constraints": "Search/window range for onset decision."
        },
        {
          "name": "d1_th",
          "type_desc": "number",
          "constraints": "First-derivative threshold."
        },
        {
          "name": "d2_th",
          "type_desc": "number",
          "constraints": "Second-derivative threshold."
        }
      ],
      "outputs": [
        {
          "name": "onsets",
          "type_desc": "array",
          "constraints": "Detected onset positions (e.g., sample indices or times)."
        }
      ],
      "status": "decomposed",
      "children": [
