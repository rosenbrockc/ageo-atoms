        "finalize_onset_array"
      ],
      "depth": 1,
      "type_signature": "(signal: 1D numeric array, sampling_rate: number, sm_size: integer, size: integer, alpha: number, wrange: integer or tuple/range, d1_th: number, d2_th: number) -> array",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Derivative-Threshold Change-Point Locator for 1D Sampled Signals. Transforms a uniformly sampled 1D numeric sequence into a sparse set of event indices by combining local smoothing, windowed feature evaluation, and derivative-based salience scoring. Candidate transition points are identified where first- and second-order temporal differences satisfy configurable threshold constraints within a search range. The result is a discrete boundary map that marks abrupt regime transitions in the original sequence.. Applications: Biomedical monitoring: detect abrupt physiological state transitions in univariate biosensor streams (e.g., respiration or electrophysiology)., Industrial reliability: identify fault onset times in machine vibration or current signals for predictive maintenance., Network engineering: mark anomaly start points in packet-rate or latency time series for incident triage., Geoscience: detect event boundaries in seismic or geophysical sensor traces for automated segmentation.",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
