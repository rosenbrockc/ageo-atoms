      "parent_id": "find_onsets_kavsaoglu2016_root",
      "name": "DetectOnsetEvents",
      "description": "Detects rhythmic onset events from an input signal using provided tempo and delay constraints as algorithm parameters.",
      "concept_type": "signal_transform",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "array-like[float]",
          "constraints": "1-D sampled signal"
        },
        {
          "name": "sampling_rate",
          "type_desc": "float",
          "constraints": "> 0"
        },
        {
          "name": "alpha",
          "type_desc": "float",
          "constraints": "algorithm coefficient"
        },
        {
          "name": "k",
          "type_desc": "int",
          "constraints": "window/order parameter, typically > 0"
        },
        {
          "name": "init_bpm",
          "type_desc": "float",
          "constraints": "initial tempo estimate, > 0"
        },
        {
          "name": "min_delay",
          "type_desc": "float",
          "constraints": "minimum inter-onset delay, >= 0"
        },
        {
          "name": "max_BPM",
          "type_desc": "float",
          "constraints": "upper tempo bound, > 0"
        }
      ],
      "outputs": [
        {
          "name": "onset_events",
          "type_desc": "array-like",
          "constraints": "detected onset locations/times; may be empty"
