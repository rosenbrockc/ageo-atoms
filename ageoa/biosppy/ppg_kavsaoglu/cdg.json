      ],
      "depth": 1,
      "type_signature": "(signal: array-like[float], sampling_rate: float, alpha: float, k: int, init_bpm: float, min_delay: float, max_BPM: float) -> array-like",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Constrained Quasi-Periodic Event Onset Extractor. Transforms a 1-D sampled real-valued sequence into a sparse set of event boundaries by computing a local change/emphasis measure with a tunable coefficient and order/window parameter. It then performs constrained peak selection under an expected event-rate prior, enforcing both a minimum inter-event interval and an upper frequency bound to reject implausibly dense detections. The result is a temporally ordered event set representing salient onset points in the original sequence.. Applications: Detecting micro-event arrival times in geophysical sensor traces under plausible recurrence-rate constraints, Identifying activation onsets in biomedical time-series (e.g., transient spikes in fluorescence or electrophysiology signals), Marking burst-start boundaries in network telemetry streams with enforced minimum spacing between incidents, Extracting impulse initiation events from industrial vibration signals for rotating machinery fault monitoring",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
