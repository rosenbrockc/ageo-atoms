    {
      "node_id": "threshold_based_onset_detection",
      "parent_id": "solnik_onset_detector_root",
      "name": "Threshold-Based Onset Detection",
      "description": "Detects activation onset points in a signal by comparing against a rest-derived baseline and enforcing a minimum active-state duration.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "array-like numeric sequence",
          "constraints": "1D time-series samples"
        },
        {
          "name": "rest",
          "type_desc": "array-like numeric sequence",
          "constraints": "baseline/rest segment used to calibrate detection"
        },
        {
          "name": "sampling_rate",
          "type_desc": "float",
          "constraints": "> 0, samples per second"
        },
        {
          "name": "threshold",
          "type_desc": "float",
          "constraints": "activation cutoff relative to baseline/rest statistics"
        },
        {
          "name": "active_state_duration",
          "type_desc": "float",
          "constraints": "minimum sustained active duration (seconds or equivalent sample window)"
        }
      ],
      "outputs": [
        {
          "name": "onset_indices",
          "type_desc": "array-like integer indices",
          "constraints": "indices marking detected onsets that satisfy threshold and duration criteria"
        }
      ],
      "status": "decomposed",
      "children": [
        "validate_required_inputs",
        "estimate_rest_baseline_statistics",
        "remove_signal_baseline_offset",
        "compute_detection_threshold",
        "derive_energy_trace_and_state_transitions",
        "merge_transition_indices"
      ],
      "depth": 1,
      "type_signature": "(signal: array-like numeric sequence, rest: array-like numeric sequence, sampling_rate: float, threshold: float, active_state_duration: float) -> array-like integer indices",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Baseline-Calibrated Persistent Excursion Onset Extraction. A reference segment is used to estimate baseline statistics, then a 1D numeric sequence is thresholded relative to that baseline to form a binary active/inactive mask. A minimum persistence constraint is applied so only supra-threshold runs with sufficient length are retained, removing short transient crossings. The output is the set of rising-edge indices (inactive to active transitions) of the retained runs.. Applications: Seismology: detect onset times of sustained waveform excursions relative to quiet-earth baseline segments., Industrial condition monitoring: detect start of persistent anomalous vibration regimes in rotating machinery streams., Neuroscience: detect burst onset events in electrophysiological traces using pre-activity calibration windows., Network telemetry: detect onset of sustained traffic-load excursions above baseline fluctuation levels.",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
