          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "signal",
          "type_desc": "1-D numeric array",
          "constraints": "original (unnormalised) signal",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "v_100ms",
          "type_desc": "positive int (samples)",
          "constraints": "look-ahead window for local argmax",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "v_300ms",
          "type_desc": "positive int (samples)",
          "constraints": "minimum refractory period between accepted peaks",
          "required": true,
