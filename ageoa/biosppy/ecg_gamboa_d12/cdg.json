      "node_id": "compute_signal_normalization_range",
      "parent_id": "gamboa_segmenter",
      "name": "compute_signal_normalization_range",
      "description": "Estimate the signal amplitude range using a 100-bin density histogram and cumulative distribution thresholding at 1% tails, then derive a normalization factor as the maximum absolute boundary value.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "1-D numeric array",
          "constraints": "non-empty",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "TH",
          "type_desc": "float",
          "constraints": "fixed at 0.01; tail-cut threshold",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "nrm",
          "type_desc": "positive float",
          "constraints": "max(|v0|, |v1|); used as divisor, must be > 0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(signal: 1-D numeric array, TH: float) -> positive float",
