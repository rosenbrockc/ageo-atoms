    {
      "node_id": "gamboa_segmenter",
      "parent_id": "gamboa_segmenter_root",
      "name": "gamboa_segmenter",
      "description": "Segments a physiological signal into individual cycles or beats using the Gamboa algorithm, operating as a single pure function that accepts a raw signal with its sampling rate and a tolerance parameter, then returns segmented boundary indices.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "1-D numeric array (time-series amplitude values)",
          "constraints": "non-empty, finite values",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "sampling_rate",
          "type_desc": "positive integer or float (Hz)",
          "constraints": "must be > 0",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "tol",
          "type_desc": "float (tolerance threshold for peak/segment detection)",
          "constraints": "must be > 0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "segments",
          "type_desc": "1-D integer array of sample indices marking segment boundaries",
          "constraints": "indices within [0, len(signal))",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "decomposed",
      "children": [
        "compute_window_samples",
