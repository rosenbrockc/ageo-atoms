    {
      "node_id": "asi_signal_segmenter",
      "parent_id": "ASI_segmenter_root",
      "name": "ASI_signal_segmenter",
      "description": "Segments an input signal into discrete intervals by applying a power/amplitude threshold (Pth) relative to the signal's sampling rate. Identifies contiguous regions where signal energy exceeds or falls below the threshold, returning segment boundary indices or masked signal regions.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "1-D numeric array (time-series samples)",
          "constraints": "must be finite, length >= 1",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "sampling_rate",
          "type_desc": "positive float (Hz)",
          "constraints": "sampling_rate > 0",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Pth",
          "type_desc": "positive float (power/amplitude threshold)",
          "constraints": "Pth > 0; determines the segmentation decision boundary",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "segments",
          "type_desc": "array of (start_sample, end_sample) integer pairs",
          "constraints": "0 <= start_sample < end_sample <= len(signal); non-overlapping, sorted ascending",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "decomposed",
      "children": [
        "initialize_detection_parameters",
        "compute_double_difference_squared",
        "integrate_with_moving_window",
        "detect_rpeaks_with_adaptive_threshold_fsm",
        "package_rpeak_results"
      ],
      "depth": 1,
      "type_signature": "(signal: 1-D numeric array (time-series samples), sampling_rate: positive float (Hz), Pth: positive float (power/amplitude threshold)) -> array of (start_sample, end_sample) integer pairs",
      "matched_primitive": null,
      "primitive_binding_confidence": 0.0,
      "primitive_binding_source": "",
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Scalar_Sequence_EnergyThreshold_Partitioner. Scans a uniformly-sampled 1-D scalar sequence and partitions it into maximally contiguous spans by comparing local magnitude or energy against a normalized decision boundary derived from the sequence's sampling density. The transform performs a binary classification on each sample (above-threshold / below-threshold) and then applies run-length encoding to collapse adjacent same-class samples into closed integer intervals, effectively reducing a dense numeric array into a sparse set of boundary pairs. The result is a lossless structural summary of the sequence's active regions, preserving topological ordering and non-overlap invariants.. Applications: Neuroscience / Electrophysiology: Detecting spike bursts or action-potential epochs in a membrane-voltage time series by isolating contiguous intervals where neural firing energy exceeds a baseline noise floor, enabling downstream inter-burst-interval analysis., Astronomy / Photometry: Segmenting a stellar flux light curve to isolate transit or flare events \u2014 contiguous intervals where photon count rate rises above a quiescent background level \u2014 prior to period-folding or morphological classification., Structural Health Monitoring: Partitioning a vibration or acoustic-emission sensor stream from a mechanical structure into active-event windows (e.g., crack propagation pulses) versus ambient noise, enabling event counting and fatigue-cycle extraction., Natural Language Processing / Acoustic Tokenization: Identifying voiced speech segments within a raw audio sample array by thresholding short-time energy, producing frame-boundary pairs that define candidate phoneme or word tokens for downstream feature extraction.",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
    {
      "node_id": "initialize_detection_parameters",
      "parent_id": "asi_signal_segmenter",
      "name": "initialize_detection_parameters",
      "description": "Compute all scalar parameters needed for the FSM detector: the moving-window length N, the delay Nd, the minimum refractory period Rmin, and pre-allocate the running amplitude accumulator Ramptotal.",
      "concept_type": "state_init",
      "inputs": [
        {
          "name": "sampling_rate",
          "type_desc": "positive float (Hz)",
          "constraints": "sampling_rate > 0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "N",
          "type_desc": "positive int",
          "constraints": "N = round(3 * sampling_rate / 128)",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Nd",
          "type_desc": "positive int",
          "constraints": "Nd = N - 1",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Rmin",
          "type_desc": "float (seconds)",
          "constraints": "Rmin = 0.26",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Ramptotal",
          "type_desc": "float",
          "constraints": "initialised to 0.0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(sampling_rate: positive float (Hz)) -> tuple[positive int, positive int, float (seconds), float]",
      "matched_primitive": null,
      "primitive_binding_confidence": 0.0,
      "primitive_binding_source": "",
