    {
      "node_id": "detect_rpeaks_with_adaptive_threshold_fsm",
      "parent_id": "asi_signal_segmenter",
      "name": "detect_rpeaks_with_adaptive_threshold_fsm",
      "description": "Run the three-state finite-state machine over the integrated energy envelope to locate R-peaks: (1) scan a Rmin-wide window for the local maximum (candidate R-peak), (2) enforce a 200 ms waiting/refractory period, (3) apply an exponentially-decaying adaptive threshold to find the next above-threshold crossing, updating the running amplitude estimate Ramptotal after each detected peak.",
      "concept_type": "sequential_filter",
      "inputs": [
        {
          "name": "processed_ecg",
          "type_desc": "1-D float array",
          "constraints": "non-negative",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "sampling_rate",
          "type_desc": "positive float",
          "constraints": "Hz",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Rmin",
          "type_desc": "float",
          "constraints": "refractory period in seconds",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Ramptotal",
          "type_desc": "float",
          "constraints": "initial running amplitude = 0.0",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Pth",
          "type_desc": "positive float",
          "constraints": "decay exponent free parameter",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "rpeaks",
          "type_desc": "list of int",
          "constraints": "1-based sample indices of detected R-peaks; sorted ascending",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(processed_ecg: 1-D float array, sampling_rate: positive float, Rmin: float, Ramptotal: float, Pth: positive float) -> list of int",
