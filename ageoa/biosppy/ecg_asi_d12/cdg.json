    {
      "node_id": "compute_double_difference_squared",
      "parent_id": "asi_signal_segmenter",
      "name": "compute_double_difference_squared",
      "description": "Apply a double finite-difference operator to the ECG signal (first a 1-step difference on the Nd-delayed signal, then a 1-step difference on that result) and square each sample to produce a non-negative energy signal.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "1-D numeric array",
          "constraints": "length >= Nd + 2",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "Nd",
          "type_desc": "positive int",
          "constraints": "Nd >= 1",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "squar",
          "type_desc": "1-D float array",
          "constraints": "length = len(signal) - Nd - 1; all values >= 0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(signal: 1-D numeric array, Nd: positive int) -> 1-D float array",
      "matched_primitive": null,
      "primitive_binding_confidence": 0.0,
      "primitive_binding_source": "",
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "",
      "critic_notes": "",
      "decomposition_rationale": ""
