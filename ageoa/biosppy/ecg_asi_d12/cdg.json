    {
      "node_id": "integrate_with_moving_window",
      "parent_id": "asi_signal_segmenter",
      "name": "integrate_with_moving_window",
      "description": "Smooth the squared double-difference signal by convolving it with a rectangular (boxcar) window of length N via a causal IIR/FIR filter, producing an integrated energy envelope used for threshold comparisons.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "squar",
          "type_desc": "1-D float array",
          "constraints": "non-negative samples",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "N",
          "type_desc": "positive int",
          "constraints": "N >= 1",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "processed_ecg",
          "type_desc": "1-D float array",
          "constraints": "same length as squar; non-negative",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
      "type_signature": "(squar: 1-D float array, N: positive int) -> 1-D float array",
      "matched_primitive": null,
