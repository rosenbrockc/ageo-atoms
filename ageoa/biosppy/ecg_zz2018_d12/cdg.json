    {
      "node_id": "computebeatagreementsqi",
      "parent_id": "ZZ2018_root",
      "name": "ComputeBeatAgreementSQI",
      "description": "Computes a beat-detector agreement quality index from two detector streams within a temporal search window.",
      "concept_type": "analysis",
      "inputs": [
        {
          "name": "detector_1",
          "type_desc": "array-like beat locations",
          "constraints": "same timeline as detector_2",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "detector_2",
          "type_desc": "array-like beat locations",
          "constraints": "same timeline as detector_1",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "fs",
          "type_desc": "float",
          "constraints": "sampling rate > 0",
          "required": true,
          "default_value_repr": ""
