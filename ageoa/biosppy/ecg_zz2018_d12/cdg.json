    {
      "node_id": "computekurtosissqi",
      "parent_id": "ZZ2018_root",
      "name": "ComputeKurtosisSQI",
      "description": "Computes kurtosis-based ECG quality score from the input signal.",
      "concept_type": "analysis",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "array-like",
          "constraints": "1-D sampled ECG",
