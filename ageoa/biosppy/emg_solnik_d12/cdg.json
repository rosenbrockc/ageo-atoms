    {
      "node_id": "solnik_onset_detect",
      "parent_id": "solnik_onset_detector_root",
      "name": "solnik_onset_detect",
      "description": "Detects movement onsets in a signal using the Solnik algorithm: identifies transitions from rest to active state by comparing signal amplitude against a threshold over a minimum active-state duration window.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "1D numeric array (time-series amplitude)",
          "constraints": "non-empty, finite values",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "rest",
          "type_desc": "numeric scalar (baseline/rest amplitude reference)",
          "constraints": "finite, typically >= 0",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "sampling_rate",
          "type_desc": "positive numeric scalar (Hz)",
          "constraints": "> 0",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "threshold",
          "type_desc": "positive numeric scalar (detection threshold multiplier or absolute level)",
          "constraints": "> 0",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "active_state_duration",
          "type_desc": "positive numeric scalar (minimum duration in seconds for a valid active state)",
          "constraints": "> 0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "onset_indices",
          "type_desc": "array of integer sample indices marking detected onset events",
          "constraints": "values in [0, len(signal)-1], monotonically increasing",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "decomposed",
