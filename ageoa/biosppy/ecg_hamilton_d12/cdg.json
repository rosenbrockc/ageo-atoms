    {
      "node_id": "hamilton_segmenter",
      "parent_id": "hamilton_segmenter_root",
      "name": "hamilton_segmenter",
      "description": "Detects R-peaks (QRS complexes) in an ECG signal using the Hamilton segmentation algorithm, returning the indices of detected peaks given a raw signal and its sampling rate.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "1-D array of ECG amplitude samples",
          "constraints": "non-empty, numeric",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "sampling_rate",
          "type_desc": "positive integer or float (Hz)",
          "constraints": "must be > 0",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "outputs": [
        {
          "name": "rpeaks",
          "type_desc": "1-D array of integer sample indices marking detected R-peaks",
          "constraints": "indices within [0, len(signal))",
          "required": true,
          "default_value_repr": ""
        }
      ],
      "status": "decomposed",
      "children": [
        "compute_algorithm_parameters",
        "bandpass_filter_signal",
