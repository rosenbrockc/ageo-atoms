          "constraints": "initial adaptive threshold",
          "required": true,
          "default_value_repr": ""
        },
        {
          "name": "qrspeakbuffer",
          "type_desc": "1-D float array",
          "constraints": "circular buffer of QRS amplitudes",
          "required": true,
          "default_value_repr": ""
        },
        {
