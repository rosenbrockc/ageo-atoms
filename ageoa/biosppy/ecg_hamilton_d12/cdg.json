      "parent_id": "hamilton_segmenter",
      "name": "detect_qrs_candidates",
      "description": "Iterates over all candidate peaks in dx and applies the Hamilton detection rules: (1) skip peaks dominated by a neighbouring peak within 200 ms, (2) require bidirectional slope in the raw signal, (3) reject T-waves when the elapsed time is <360 ms and slope is <50% of previous, (4) classify peaks above DT as QRS or noise, (5) rescue missed beats when no detection occurs within 1.5\u00d7RRM, updating the adaptive buffers and RR-interval buffer after every decision.",
      "concept_type": "searching",
      "inputs": [
        {
          "name": "all_peaks",
          "type_desc": "1-D int array",
          "constraints": "local maxima indices of dx",
          "required": true,
          "default_value_repr": ""
        },
        {
