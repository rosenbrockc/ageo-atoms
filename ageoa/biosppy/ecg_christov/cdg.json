    {
      "node_id": "christovqrsdetect",
      "parent_id": "christov_segmenter_root",
      "name": "ChristovQRSDetect",
      "description": "Detects QRS complexes in an ECG signal using the Christov real-time algorithm, which applies a series of signal transformations and adaptive thresholding to locate R-peak positions and return segmentation indices.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "np.ndarray",
          "constraints": "finite real values, length >= 1"
        },
        {
          "name": "sampling_rate",
          "type_desc": "float",
          "constraints": "sampling_rate > 0"
        }
      ],
      "outputs": [
        {
          "name": "rpeaks",
          "type_desc": "np.ndarray",
          "constraints": "values in [0, len(signal)-1], monotonically increasing"
        }
      ],
      "status": "decomposed",
      "children": [
        "compute_timing_constants",
        "suppress_powerline_and_emg_noise",
        "bandpass_filter_signal",
        "compute_nonlinear_energy_operator",
        "smooth_energy_envelope",
        "initialise_adaptive_state",
        "run_adaptive_threshold_detection",
        "refine_rpeaks_on_raw_signal"
      ],
      "depth": 1,
      "type_signature": "(signal: 1-D numeric array (ECG amplitude samples), sampling_rate: positive integer or float (Hz)) -> 1-D integer array of sample indices",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "AdaptiveThresholdExtremaLocator. Applies a cascade of nonlinear signal transformations (e.g., differentiation, squaring, moving-window integration) to a uniformly-sampled 1-D scalar time-series to amplify periodic impulsive features while suppressing baseline drift and noise. An adaptive, time-varying threshold is then continuously updated based on recent signal statistics, and threshold-crossing events are resolved into a monotonically increasing sequence of discrete integer indices that mark the temporal positions of dominant local extrema. The algorithm operates causally and in near-real-time, requiring only a fixed-size historical buffer rather than the full signal.. Applications: Seismology: locating P-wave and S-wave arrival onset indices within a continuous geophone or accelerometer time-series for earthquake event cataloging, Industrial condition monitoring: detecting impulsive mechanical shock events (e.g., bearing fault spikes) in a vibration sensor stream for predictive maintenance triggering, Neuroscience / electrophysiology: identifying action potential firing times (spike sorting step 0) in extracellular multi-unit neural recordings sampled at high frequency, Acoustic / audio analysis: segmenting percussive onset events in an audio amplitude envelope (e.g., drum hit detection, sonar pulse returns) for beat-tracking or range-finding pipelines",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
