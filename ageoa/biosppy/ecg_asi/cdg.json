      "node_id": "thresholdbasedsignalsegmentation",
      "parent_id": "ASI_segmenter_root",
      "name": "ThresholdBasedSignalSegmentation",
      "description": "Segments the input signal into activity regions using the provided sampling rate and decision threshold.",
      "concept_type": "signal_filter",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "np.ndarray",
          "constraints": "1-D or compatible signal shape; finite values preferred"
        },
        {
          "name": "sampling_rate",
          "type_desc": "float",
          "constraints": "must be > 0"
        },
        {
          "name": "Pth",
          "type_desc": "float",
          "constraints": "threshold parameter used for segmentation decision"
        }
      ],
      "outputs": [
        {
          "name": "segments",
          "type_desc": "object",
          "constraints": "derived deterministically from inputs"
        }
      ],
      "status": "decomposed",
      "children": [
        "computedetectionkernelparameters",
        "enhanceqrswithsquareddoubledifference",
        "integrateenergyovermovingwindow",
        "detectrpeakswithadaptivethreestatefsm",
        "packagerpeakoutput"
      ],
      "depth": 1,
      "type_signature": "(signal: array-like numeric sequence, sampling_rate: float, Pth: float) -> segmentation result (e.g., intervals, labels, or mask)",
      "matched_primitive": null,
      "is_optional": false,
      "is_opaque": false,
      "is_external": false,
      "parallelizable": false,
      "conceptual_summary": "Threshold-Driven Sequence Partitioning. Applies a scalar decision boundary to a sampled numeric sequence to classify each sample as active or inactive, then merges contiguous active samples into contiguous regions. The positive sampling density parameter maps sample indices to a continuous coordinate system so region boundaries can be expressed as index ranges or coordinate intervals. The output is a deterministic partition of the sequence into above-threshold and non-above-threshold regions.. Applications: Structural health monitoring: partition vibration traces into transient-event regions versus baseline dynamics, Neuroscience: isolate high-activation epochs in electrophysiology recordings for event-rate analysis, Network engineering: segment throughput/latency telemetry into congestion episodes and nominal intervals, Astrophysics: detect burst intervals in photon-count time series above background intensity",
      "critic_notes": "",
      "decomposition_rationale": ""
    },
    {
      "node_id": "computedetectionkernelparameters",
      "parent_id": "thresholdbasedsignalsegmentation",
      "name": "ComputeDetectionKernelParameters",
      "description": "Derive window sizes and loop bounds from sampling rate and signal length for derivative, refractory, and stop conditions.",
      "concept_type": "arithmetic",
      "inputs": [
        {
          "name": "signal",
          "type_desc": "np.ndarray",
          "constraints": "length >= 2"
        },
        {
          "name": "sampling_rate",
          "type_desc": "float",
          "constraints": "sampling_rate > 0"
        }
      ],
      "outputs": [
        {
          "name": "N",
          "type_desc": "int",
          "constraints": "N = round(3 * sampling_rate / 128), N >= 1"
        },
        {
          "name": "Nd",
          "type_desc": "int",
          "constraints": "Nd = N - 1"
        },
        {
          "name": "Rmin",
          "type_desc": "float",
          "constraints": "fixed at 0.26 seconds"
        },
        {
          "name": "stop_index",
          "type_desc": "int",
          "constraints": "stop_index = len(signal) - sampling_rate"
        }
      ],
      "status": "atomic",
      "children": [],
      "depth": 2,
